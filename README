# 1. Setup
python -m venv venv
source venv/Scripts/activate
pip install -r requirements.txt

# 2. Add your API key
cp .env.example .env
# edit .env → OPENAI_API_KEY=sk-...

# 3. Drop all course PDFs into data/pdfs/

# 4. Build the vector store (once)
python ingest.py

# 5. Launch
python app.py          # opens http://localhost:7860
# or CLI test:
python tutor.py